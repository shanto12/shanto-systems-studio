{
  "name": "shanto-systems-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Premium motion website for Shanto Systems Studio with paired day/night hero media and interactive systems choreography.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:prod": "PLAYWRIGHT_BASE_URL=https://shanto-systems-studio.netlify.app playwright test",
    "verify:prod": "npm run e2e:prod",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:release": "npm run verify && npm run e2e",
    "verify:release:full": "npm run verify:release && npm run verify:prod"
  },
  "dependencies": {
    "lucide-react": "^0.556.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
